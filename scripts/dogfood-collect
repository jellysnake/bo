#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
CORPORA_DIR="$ROOT/corpora"

usage() {
  echo "usage: $0 [tree-corpus]" >&2
  echo >&2
  echo "Each corpus maps 1:1 to one temp bo tree." >&2
  echo "default corpus: default" >&2
  echo >&2
  echo "available corpora:" >&2
  find "$CORPORA_DIR" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; 2>/dev/null | sort | sed 's/^/  /' >&2
}

if [[ $# -eq 1 && ("${1:-}" == "-h" || "${1:-}" == "--help") ]]; then
  usage
  exit 0
fi

if [[ $# -gt 1 ]]; then
  usage
  exit 2
fi

CORPUS="${1:-default}"
URLS="$CORPORA_DIR/$CORPUS/urls.txt"
if [[ ! -f "$URLS" ]]; then
  echo "unknown corpus: $CORPUS" >&2
  usage
  exit 2
fi

RUN_DIR="$(mktemp -d "${TMPDIR:-/tmp/}bo-dogfood-${CORPUS}.XXXXXX")"
HOME_DIR="$RUN_DIR/home"
TREE="$RUN_DIR/tree"
LOG="$RUN_DIR/run.log"
RESULTS="$RUN_DIR/results.tsv"
BIN="$ROOT/target/debug/bo"

mkdir -p "$HOME_DIR"
: >"$LOG"
printf 'url\tresult\texit_code\n' >"$RESULTS"

(cd "$ROOT" && cargo build --quiet --bin bo)

{
  echo "tree corpus: $CORPUS"
  echo "urls: $URLS"
  echo "run: $RUN_DIR"
  echo "tree: $TREE"
  echo
  HOME="$HOME_DIR" "$BIN" seed "$TREE"
} >>"$LOG" 2>&1

ok=0
failed=0

while IFS= read -r raw || [[ -n "$raw" ]]; do
  url="$(printf '%s' "$raw" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
  if [[ -z "$url" || "${url:0:1}" == "#" ]]; then
    continue
  fi

  printf 'collect %s\n' "$url"
  printf '\n==> %s\n' "$url" >>"$LOG"

  if HOME="$HOME_DIR" "$BIN" collect "$url" >>"$LOG" 2>&1; then
    printf '%s\tok\t0\n' "$url" >>"$RESULTS"
    ok=$((ok + 1))
  else
    code=$?
    printf '%s\tfail\t%s\n' "$url" "$code" >>"$RESULTS"
    failed=$((failed + 1))
  fi
done <"$URLS"

echo
echo "done: $ok ok, $failed failed"
echo "run: $RUN_DIR"
echo "tree: $TREE"
echo "log: $LOG"
echo "results: $RESULTS"
